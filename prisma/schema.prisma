generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  conversations Conversation[]
  achievements  Achievement[]
  settings      Settings?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Conversation {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       Message[]
  creatureStates CreatureState[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           Role
  content        String
  sentiment      Float?
  emotion        String?
  createdAt      DateTime     @default(now())
  uploads        Upload[]
}

enum Role {
  USER
  AI
  SYSTEM
}

model Memory {
  id        String   @id @default(cuid())
  userId    String // Not strongly relating to allow cross-system caching
  topic     String
  summary   String
  type      String // Habit, Like, Dislike, Goal
  weight    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreatureState {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  mood           String // happy, idle, roasting
  energy         Int          @default(100)
  createdAt      DateTime     @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // Night Owl, Yapper, etc.
  unlockedAt  DateTime @default(now())
}

model Upload {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  type      String
  createdAt DateTime @default(now())
}

model Settings {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalityMode  String @default("Best Friend")
  theme            String @default("light")
  enableAnimations Boolean @default(true)
}
